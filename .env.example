# Application Configuration
NODE_ENV=development
APP_PORT=8080
LOG_LEVEL=info

# Database Configuration
DB_USER=user
DB_PASSWORD=change_me_in_production
DB_NAME=mydatabase
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# Security Configuration
# IMPORTANT: Change these API keys in production!
# Generate strong keys using: openssl rand -hex 32
VALID_API_KEYS=dev-key-1234567890,dev-key-abcdefghij,dev-key-zyxwvutsrq

# Export Configuration
EXPORT_PATH=/app/output

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Production Notes:
# 1. Never commit the actual .env file to version control
# 2. Use strong, randomly generated API keys in production
# 3. Change DB_PASSWORD to a strong password
# 4. Set NODE_ENV=production in production environments
# 5. Consider using a secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)